{
  "private": true,
  "packageManager": "pnpm@10.18.3",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "dependencies": {
    "@expo/ui": "~57.0.1",
    "@react-native-community/netinfo": "12.0.1",
    "@react-native-segmented-control/segmented-control": "^2.5.7",
    "axios": "^1.18.1",
    "expo": "~57.0.1",
    "expo-apple-authentication": "~57.0.0",
    "expo-clipboard": "~57.0.0",
    "expo-constants": "~57.0.2",
    "expo-dev-client": "^57.0.4",
    "expo-device": "~57.0.0",
    "expo-document-picker": "~57.0.0",
    "expo-file-system": "~57.0.0",
    "expo-font": "~57.0.0",
    "expo-glass-effect": "~57.0.0",
    "expo-image": "~57.0.0",
    "expo-image-picker": "~57.0.2",
    "expo-ios-emoji-picker": "^0.1.0",
    "expo-ios-select-picker": "^0.1.0",
    "expo-linking": "~57.0.1",
    "expo-local-authentication": "~57.0.0",
    "expo-media-library": "~57.0.1",
    "expo-notifications": "~57.0.3",
    "expo-router": "~57.0.2",
    "expo-secure-store": "~57.0.0",
    "expo-splash-screen": "~57.0.1",
    "expo-status-bar": "~57.0.0",
    "expo-system-ui": "~57.0.0",
    "expo-updates": "~57.0.6",
    "expo-web-browser": "~57.0.0",
    "laravel-echo": "2.3.1",
    "nativewind": "4.2.6",
    "phosphor-react-native": "^3.0.6",
    "pusher-js": "8.4.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.86.0",
    "react-native-css-interop": "0.2.6",
    "react-native-gesture-handler": "~2.32.0",
    "react-native-reanimated": "4.5.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-svg": "^15.15.5",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.10.0",
    "tailwindcss": "3.4.19",
    "ziggy-js": "^2.6.3"
  },
  "devDependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "@types/react": "~19.2.2",
    "babel-preset-expo": "57.0.1",
    "eas-cli": "^20.5.1",
    "eslint": "^9.39.4",
    "eslint-config-expo": "~57.0.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.9.4",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "react-native-svg-transformer": "^1.5.3",
    "svgo": "^4.0.1",
    "typescript": "~6.0.3"
  },
  "scripts": {
    "start": "expo start",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "lint": "expo lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "routes:generate": "node ./scripts/generate-routes.mjs",
    "tokens:build": "node ./scripts/build-tokens.mjs",
    "icons:tabs": "node ./scripts/generate-tab-icons.mjs",
    "icons:segments": "node ./scripts/generate-segment-icons.mjs",
    "svg:optimize": "svgo -f assets",
    "local:build": "eas build --platform ios --local --non-interactive --freeze-credentials --output ./build/dev-client.ipa --profile local",
    "local:install": "ios-deploy --bundle ./build/dev-client.ipa",
    "ios:build:production": "eas build --platform ios --local --output ./build/app.ipa --profile production --freeze-credentials --non-interactive",
    "ios:submit": "eas submit --platform ios --path ./build/app.ipa --profile production --non-interactive",
    "ios:release": "pnpm ios:build:production && pnpm ios:submit",
    "ota:production": "eas update --channel production --environment production --message \"Production release\" --non-interactive"
  },
  "name": "app"
}
