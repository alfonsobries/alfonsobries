{
  "expo": {
    "name": "Alfonso's App",
    "slug": "alfonsobries",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "alfonsobries",
    "userInterfaceStyle": "automatic",
    "runtimeVersion": "1.2.0",
    "updates": {
      "url": "https://u.expo.dev/fbd135b1-6baa-4be2-b789-254386da114d"
    },
    "ios": {
      "bundleIdentifier": "com.alfonsobries.app",
      "usesAppleSignIn": true,
      "icon": {
        "light": "./assets/images/icon.png",
        "dark": "./assets/images/icon-dark.png",
        "tinted": "./assets/images/icon-tinted.png"
      },
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.alfonsobries.app",
      "adaptiveIcon": {
        "backgroundColor": "#ffd78b",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-apple-authentication",
      "expo-secure-store",
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Confirm it's you to do certain actions."
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#ffd78b",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 76
        }
      ],
      "expo-notifications",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow $(PRODUCT_NAME) to access your photos to choose and upload images.",
          "cameraPermission": "Allow $(PRODUCT_NAME) to use the camera to take photos."
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "Allow $(PRODUCT_NAME) to access your photos.",
          "savePhotosPermission": "Allow $(PRODUCT_NAME) to save photos to your library."
        }
      ],
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "fbd135b1-6baa-4be2-b789-254386da114d"
      }
    }
  }
}
