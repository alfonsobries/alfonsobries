# Base URL of the Laravel API, including the `/api` suffix.
# Simulators reach the host over localhost; physical devices need the LAN IP
# (the `start-mobile.sh` script fills this in automatically).
EXPO_PUBLIC_API_URL=http://localhost:8000/api

# Sign in with Apple on iOS needs no client-side secret — it uses the native
# bundle identifier. Credential setup lives in docs/apple-sign-in.md.
