APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
FRONT_URL=http://localhost:3000

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=api
DB_USERNAME=root
DB_PASSWORD=

# Live updates over websockets (a shared Reverb server; `reverb` in prod)
BROADCAST_DRIVER=log
REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST=ws.vexilo.com
REVERB_PORT=443
REVERB_SCHEME=https
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=fals

# AI providers. OpenAI covers the default chat + image models; Anthropic
# unlocks the Claude chat models and xAI the Grok Imagine image model in the
# in-app model picker (config/site.php `chat.models` and config/images.php).
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
XAI_API_KEY=

# Chat assistants (laravel/ai); an Assistant record can override both, and
# the in-app model picker overrides the model at runtime
AI_CHAT_PROVIDER=openai
AI_CHAT_MODEL=gpt-5.1

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=mt1

VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_HOST="${PUSHER_HOST}"
VITE_PUSHER_PORT="${PUSHER_PORT}"
VITE_PUSHER_SCHEME="${PUSHER_SCHEME}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

VERCEl_DEPLOYMENT_URL=https://api.vercel.com/v1/integrations/deploy/prj_

ADMIN_NAME=
ADMIN_EMAIL=
ADMIN_PASSWORD=

# Apple subs of the two people who use the app, so the code can tell them apart
# once signed in. Leave empty in public/dev environments.
ALFONSO_APPLE_ID=
SAIDA_APPLE_ID=

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

NODE_BINARY="/usr/bin/node"
NPM_BINARY="/usr/bin/npm"

# Should match the frontend SECRET_PREFIX value
SECRET_PREFIX=preview

NOVA_DOMAIN_NAME=
NOVA_LICENSE_KEY=
NOVA_PATH=/
# Sign in with Apple — see docs/apple-sign-in.md
# The iOS bundle identifier; must equal the `aud` of the identity tokens the app
# sends. Defaults to com.alfonsobries.app when unset.
APPLE_CLIENT_ID=com.alfonsobries.app
# Optional Apple Services ID, only needed for a future web/Android sign-in flow.
APPLE_SERVICES_ID=

# Shared secret that signs the OTA-published webhook (must match EAS_NOTIFY_SECRET in app/.env)
EAS_NOTIFY_SECRET=
