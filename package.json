  },
  "dependencies": {
    "@alfonsobries/react-use-form": "^0.4.0",
    "@tailwindui/react": "^0.1.1",
    "axios": "^1.18.1",
    "classnames": "^2.5.1",
    "date-fns": "^2.28.0",
    "gray-matter": "^4.0.3",
    "i18next": "^26.3.3",
    "next": "^16.2.9",
    "next-i18next": "^16.0.7",
    "next-sitemap": "^4.2.3",
    "next-themes": "^0.2.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-i18next": "^17.0.8",
    "react-svg": "^17.2.4",
    "rehype-external-links": "^3.0.0",
    "rehype-stringify": "^10.0.1",
    "remark": "^15.0.1",
    "remark-html": "^16.0.1",
