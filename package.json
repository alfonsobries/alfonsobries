{
  "private": true,
  "packageManager": "pnpm@10.18.3",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "next",
    "build": "next build",
    "postbuild": "next-sitemap",
    "start": "next start",
    "typecheck": "tsc",
    "lint": "next lint",
    "svg-optimize": "svgo -f ./public/images -o ./public/images",
    "svg-animate": "svgo --config ./svgo.animate.config.js -f ./assets/animations -o ./public/images",
    "prepare": "pnpm svg-optimize && pnpm typecheck && pnpm lint"
  },
  "dependencies": {
    "@alfonsobries/react-use-form": "^0.4.0",
    "@tailwindcss/aspect-ratio": "^0.4.2",
    "@tailwindcss/forms": "^0.5.2",
    "@tailwindui/react": "^0.1.1",
    "axios": "^1.18.1",
    "classnames": "^2.5.1",
    "date-fns": "^2.28.0",
    "gray-matter": "^4.0.3",
    "i18next": "^22.5.0",
    "next": "^15.5.18",
    "next-i18next": "^13.2.2",
    "next-sitemap": "^4.2.3",
    "next-themes": "^0.2.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-i18next": "^12.3.1",
    "react-svg": "^17.2.4",
    "rehype-external-links": "^3.0.0",
    "rehype-stringify": "^10.0.1",
    "remark": "^15.0.1",
    "remark-html": "^16.0.1",
    "remark-rehype": "^11.1.2"
  },
  "devDependencies": {
    "@tailwindcss/line-clamp": "^0.4.0",
    "@tailwindcss/typography": "^0.5.4",
    "@types/node": "^26.0.1",
    "@types/react": "^18.0.15",
    "@types/react-dom": "^18.0.6",
    "autoprefixer": "^10.4.7",
    "eslint": "^8.20.0",
    "eslint-config-next": "^15.5.18",
    "eslint-config-prettier": "^8.5.0",
    "postcss": "^8.4.14",
    "prettier": "^2.7.1",
    "prettier-plugin-tailwindcss": "^0.1.12",
    "svg-path-to-polygons": "^0.1.0",
    "svgo": "^2.8.0",
    "tailwindcss": "^3.1.4",
    "typescript": "^6.0.3"
  },
  "resolutions": {
    "@babel/runtime": "^7.26.10"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "sharp",
      "unrs-resolver"
    ]
